# "production" activa la cookie de sesión "secure" (requiere HTTPS) y confía
# en el proxy (nginx, etc.) para detectarlo. En desarrollo local, dejar vacío.
NODE_ENV=

PUERTO=3000
BD_HOST=localhost
BD_USER=toto_app
BD_PASS=cambiar_esto
BD_BD=cuchillos
BD_PORT=5432

# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_FIRMA=cambiar_esto_por_un_string_random_largo
COOKIE_FIRMA=cambiar_esto_por_otro_string_random_largo

# Credenciales del usuario administrador que crea `npm run crear-admin`
ADMIN_USER=admin
ADMIN_PASS=cambiar_esto_por_una_clave_fuerte
